# Copy to .env.local and fill in. NEVER commit .env.local.

# === LLM providers ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Voice runtime ===
ELEVENLABS_API_KEY=

# === Scraper ===
FIRECRAWL_API_KEY=

# === Supabase (Frankfurt eu-central-1) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Telephony (W2+) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# === SMS (W2+) ===
SMSAPI_TOKEN=

# === App config ===
# Public URL of the deployed backend used by ElevenLabs server-tool webhooks.
# Local dev: a tunnel URL (ngrok/cloudflared/zrok) pointing at apps/backend on :3001.
PUBLIC_BACKEND_URL=
