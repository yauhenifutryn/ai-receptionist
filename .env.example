# Copy to .env.local and fill in. NEVER put real values in THIS file (.env.example is committed).
# .env.local is gitignored — that's where the real values go.

# === LLM providers ===
# Primary: Google Gemini for backend LLM work (scraper consolidation, ontology
# bootstrap, consent classifier). Paid tier required for gemini-3.1-pro-preview.
# Get key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Optional. Only needed if/when ConvAI's agent-runtime LLM is Anthropic Sonnet
# AND we're calling it directly outside ConvAI. Day-9 verify item.
ANTHROPIC_API_KEY=

# Optional. Only needed if we benchmark vs Gemini OR Firecrawl's extract feature
# is enabled (it defaults to GPT-4o-mini).
OPENAI_API_KEY=

# === Voice runtime ===
# ElevenLabs API key. Free tier OK for browser-test dev; upgrade to Creator when
# wiring a real Twilio number. Settings to harden in workspace UI: training-data
# OFF, audio retention 0, transcript retention 0.
ELEVENLABS_API_KEY=
# Polish-native multilingual voice locked for the pilot.
# https://elevenlabs.io/app/api/voice-library?voiceId=mr1ubFaLs5xVrh1EqWtc
ELEVENLABS_VOICE_ID=mr1ubFaLs5xVrh1EqWtc
# HMAC secret ElevenLabs signs webhook payloads with. Required in production
# for /api/post-call and /api/tools/* — without it those routes refuse
# requests. In dev (NODE_ENV != production) missing secret degrades to a
# warning so the local React widget (which doesn't sign) still works.
ELEVENLABS_WEBHOOK_SECRET=

# === Scraper ===
FIRECRAWL_API_KEY=

# === Supabase (EU region — Ireland eu-west-1) ===
# URL is public-safe (it's published to the browser anyway). Keep blank here;
# fill in .env.local.
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (browser-safe, RLS-gated). Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key (backend-only, bypasses RLS). Format: sb_secret_...
# NEVER expose this to the browser, NEVER commit it, NEVER paste in chat.
SUPABASE_SERVICE_ROLE_KEY=

# === Telephony (W2+) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# === SMS (W2+) ===
SMSAPI_TOKEN=

# === App config ===
# Public, publicly-reachable URL of the deployed Next.js app. Used as the
# base for ElevenLabs server-tool webhooks (/api/tools/*) and the post-call
# webhook (/api/post-call). In production, /api/provision REFUSES to use
# a localhost / private-IP origin and falls back to this env. In dev,
# leaving this blank uses req.nextUrl.origin (localhost) — fine for local
# React-widget tests; for cloud testing use an ngrok URL.
PUBLIC_BASE_URL=
